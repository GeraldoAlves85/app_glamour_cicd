# =============================================
# CATALOG MICROSERVICE - ENVIRONMENT VARIABLES
# =============================================

# Database Connection (MySQL)
# Para desenvolvimento local (fora do Docker)
DATABASE_URL="mysql://root:root123@localhost:3307/catalog_db"

# Para uso DENTRO do container Docker
# DATABASE_URL="mysql://catalog_user:catalog_pass@mysql-catalog:3306/catalog_db"

# Server Configuration
PORT=3001
NODE_ENV=development

# Logging
LOG_LEVEL=debug
ENABLE_REQUEST_LOGGING=true

# CORS
CORS_ORIGIN="http://localhost:3000,http://localhost:3005"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Cache (Redis - Futuro)
REDIS_URL="redis://localhost:6379"
CACHE_TTL=3600